# ============================================
# 自动化种子生成工具 - 配置文件
# ============================================
# ⚠️ 重要提示：
#   1. 复制本文件为 .env
#   2. 填写以下【必需配置】，否则脚本无法运行
#   3. 脚本只从 .env 文件读取，不读取系统环境变量
# ============================================

# ============================================
# 【必需配置】缺少会导致脚本报错退出
# ============================================

# SMB 根路径（本地访问的方式）
# Windows 格式: \\192.168.1.100\share
# Linux/Mac 格式: //192.168.1.100/share
SMB_ROOT_PATH=//192.168.1.100/share

# 服务器绝对路径（qBittorrent 所在服务器的实际路径）
# 这是 SMB 共享在服务器上映射到的绝对路径
SERVER_ROOT_PATH=/home/user/data

# qBittorrent 服务器地址
QB_HOST=192.168.1.100

# Web UI 端口
QB_PORT=8080

# Web UI 登录凭据
QB_USERNAME=admin

# ⚠️ 必须修改此项！
QB_PASSWORD=你的密码

# ============================================
# 【可选配置】可根据需要填写
# ============================================

# SMB 认证（当前 Windows UNC 方案默认复用系统/资源管理器已登录凭据，
# 此处暂保留为兼容字段，通常无需填写）
SMB_USER=
SMB_PASS=

# 默认 Tracker 列表（逗号分隔多个）
# 示例: TRACKERS=https://tracker1.com/announce,https://tracker2.com/announce
TRACKERS=

# 种子注释（留空表示不写入 comment 元数据）
TORRENT_COMMENT=
